# =====================================================================
# Variables d'environnement Vercel uniquement
# =====================================================================
# Tout ce qui est ci-dessous va dans :
#   Vercel Dashboard > Settings > Environment Variables
# (PAS dans ce fichier en prod, juste pour référence dev local).
#
# AUCUN préfixe VITE_* — les clés sont serveur uniquement et ne doivent
# JAMAIS être bundlées côté client.
# =====================================================================

# Resend — pour /api/send-quote, /api/book-call et /api/apporteurs-candidature
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Nexus Développement <noreply@send.nexusdeveloppement.fr>
ADMIN_EMAIL=contact.nexus.developpement@gmail.com

# Optionnel : adresse spécifique pour les candidatures apporteur (page /apporteurs).
# Si non défini, le programme retombe sur ADMIN_EMAIL.
EMAIL_TO_RECRUITMENT=contact.nexus.developpement@gmail.com
